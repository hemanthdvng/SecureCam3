<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/colorPrimary"
    android:gravity="center" android:padding="28dp">
    <ImageView android:layout_width="72dp" android:layout_height="72dp"
        android:src="@android:drawable/ic_menu_camera" android:tint="@color/colorAccent"
        android:contentDescription="Logo"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:text="SecureCam"
        android:textColor="@color/colorTextPrimary" android:textSize="30sp" android:textStyle="bold"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="4dp" android:text="Choose your role"
        android:textColor="@color/colorTextSecondary" android:textSize="14sp"/>
    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="40dp" app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="16dp">
        <LinearLayout android:id="@+id/btnCamera" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="24dp" android:gravity="center"
            android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📷" android:textSize="44sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:text="Camera Mode"
                android:textColor="@color/colorTextPrimary" android:textSize="20sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:text="Stream live video with AI detection"
                android:textColor="@color/colorTextSecondary" android:textSize="13sp" android:gravity="center"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="16dp" app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="16dp">
        <LinearLayout android:id="@+id/btnViewer" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="24dp" android:gravity="center"
            android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👁" android:textSize="44sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:text="Viewer Mode"
                android:textColor="@color/colorTextPrimary" android:textSize="20sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:text="Watch the remote camera live"
                android:textColor="@color/colorTextSecondary" android:textSize="13sp" android:gravity="center"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <TextView android:id="@+id/tvLastRoom" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="20dp" android:textColor="@color/colorAccent" android:textSize="13sp" android:visibility="gone"/>
    <Button android:id="@+id/btnSettings" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="24dp" android:text="⚙️ Settings" android:textColor="@color/colorTextSecondary"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>
    <TextView android:id="@+id/versionText" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:textColor="@color/colorTextHint" android:textSize="11sp"/>
</LinearLayout>